#!/usr/bin/env bash
# After a branch checkout (or initial clone checkout), restore all
# managed dev-time symlinks if their canonical targets are available.
#
# Args: <prev-HEAD> <new-HEAD> <is-branch-checkout (0|1)>
set -e
IS_BRANCH="${3:-0}"
if [[ "$IS_BRANCH" == "1" ]]; then
    HOOKS_DIR="$(git rev-parse --show-toplevel)/.githooks"
    "$HOOKS_DIR/swap-graphinator.sh" symlink
    "$HOOKS_DIR/swap-askmilo.sh"     symlink
fi
